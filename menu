#!/bin/bash

# ZIVPN UPDATE FUNCTION
update_zivpn() {
   python3 -c "
import json, sys
from datetime import datetime
ufile = '/etc/zivpn/users.json'; cfile = '/etc/zivpn/config.json'
try:
    with open(ufile, 'r') as f: users = json.load(f)
except: users = []
try:
    with open(cfile, 'r') as f: cfg = json.load(f)
except: cfg = {}
valid = set()
for u in users:
    exp = u.get('expires'); is_valid = True
    if exp:
        try:
            if datetime.strptime(exp, '%Y-%m-%d').date() < datetime.now().date(): is_valid = False
        except: pass
    if is_valid and u.get('password'): valid.add(str(u['password']))
if 'auth' not in cfg or not type(cfg['auth']) is dict: cfg['auth'] = {}
cfg['auth']['mode'] = 'passwords'
cfg['auth']['config'] = sorted(list(valid))
with open(cfile, 'w') as f: json.dump(cfg, f, indent=2)
" > /dev/null 2>&1
   systemctl restart zivpn.service > /dev/null 2>&1
}

IP=$(wget -qO- ipv4.icanhazip.com)
[[ -f /etc/domain ]] && HOST_DOMAIN=$(cat /etc/domain) || HOST_DOMAIN="No-Domain"

# MAIN MENU
while true; do
clear
echo -e "\033[38;5;226m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
echo -e "\033[38;5;40m       🚀 ZIVPN UDP MANAGER (Standalone) 🚀\033[0m"
echo -e "\033[38;5;196m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
echo -e "\033[1;36m┃\033[1;33m IP: \033[1;37m$IP\033[0m"
echo -e "\033[1;36m┃\033[1;33m Domain: \033[1;37m$HOST_DOMAIN\033[0m"
echo -e "\033[1;36m┣━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
echo -e "\033[1;35m[\033[1;36m1\033[1;35m] \033[1;32m◈ \033[1;37mအကောင့်ဖန်တီးရန် (Create Account)"
echo -e "\033[1;35m[\033[1;36m2\033[1;35m] \033[1;32m◈ \033[1;37mအကောင့်ဖျက်ရန် (Delete Account)"
echo -e "\033[1;35m[\033[1;36m3\033[1;35m] \033[1;32m◈ \033[1;37mသက်တမ်းတိုးရန် (Renew Account)"
echo -e "\033[1;35m[\033[1;36m4\033[1;35m] \033[1;32m◈ \033[1;37mအကောင့်များစစ်ရန် (List Accounts)"
echo -e "\033[1;35m[\033[1;36m0\033[1;35m] \033[1;32m◈ \033[1;31mထွက်မည် (Exit)"
echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
read -p "ရွေးချယ်ရန် နံပါတ်: " opt

case $opt in
    1)
        clear
        echo -e "\E[44;1;37m        CREATE ZIVPN UDP ACCOUNT         \E[0m"
        echo ""
        read -p "◈ Username    : " nome
        read -p "◈ Password    : " senha
        read -p "◈ Expire Days : " dias
        
        useradd -M -s /bin/false "$nome" > /dev/null 2>&1
        echo "$nome:$senha" | chpasswd > /dev/null 2>&1
        
        python3 -c "
import json, sys
from datetime import datetime, timedelta
user = '$nome'; password = '$senha'; days = int('$dias')
expires = (datetime.now() + timedelta(days=days)).strftime('%Y-%m-%d')
ufile = '/etc/zivpn/users.json'
try:
    with open(ufile, 'r') as f: users = json.load(f)
except: users = []
replaced = False
for u in users:
    if u.get('user','').lower() == user.lower():
        u['password'] = password; u['expires'] = expires; replaced = True; break
if not replaced: users.append({'user':user, 'password':password, 'expires':expires})
with open(ufile, 'w') as f: json.dump(users, f, indent=2)
"
        update_zivpn
        validade2=$(date '+%d/%m/%Y' -d " +$dias days")
        
        clear
        echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
        echo -e "\033[1;32m🚀Thu Ya Zaw🚀 ZiVPN UDPအကောင့်ဖန်တီးပြီးပါပြီခင်ဗျာ\033[0m"
        echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
        echo -e "\033[1;31m            🔻🔻🔻🔻🔻🔻\033[0m\n"
        echo -e "\033[1;33m◈📡 Host / IP   :⪧  \033[1;37m$IP\033[0m\n"
        echo -e "\033[1;33m◈Domain :⪧ \033[1;37m$HOST_DOMAIN\033[0m\n"
        echo -e "\033[1;33m◈🧸 Username :⪧ \033[1;37m$nome\033[0m\n"
        echo -e "\033[1;33m◈🔏 Password :⪧ \033[1;37m$senha\033[0m\n"
        echo -e "\033[1;33m◈🕰 Expire Date :⪧ \033[1;37m$validade2\033[0m\n"
        echo -e "\033[1;36m           ◈Facebook :⪧လင့်◈\033[0m"
        echo -e "\033[1;32m            🔰🔰🔰🔰🔰🔰🔰\033[0m"
        echo -e "\033[1;34m https://www.facebook.com/share/1CFG2UQzrD/ \033[0m"
        echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
        read -n 1 -s -r -p "Press any key to return..."
        ;;
    2)
        clear
        echo -e "\E[41;1;37m        DELETE ZIVPN UDP ACCOUNT         \E[0m"
        read -p "◈ ဖျက်လိုသော Username: " nome
        python3 -c "
import json
ufile = '/etc/zivpn/users.json'
try:
    with open(ufile, 'r') as f: users = json.load(f)
except: users = []
user = '$nome'
new_users = [u for u in users if u.get('user','').lower() != user.lower()]
with open(ufile, 'w') as f: json.dump(new_users, f, indent=2)
"
        update_zivpn
        userdel "$nome" > /dev/null 2>&1
        echo -e "\n\033[1;32m✅ Account '$nome' ဖျက်ပစ်လိုက်ပါပြီ!\033[0m"
        read -n 1 -s -r -p "Press any key to return..."
        ;;
    3)
        clear
        echo -e "\E[42;1;37m        RENEW ZIVPN UDP ACCOUNT         \E[0m"
        read -p "◈ သက်တမ်းတိုးလိုသော Username: " nome
        read -p "◈ တိုးလိုသော ရက်အရေအတွက်: " dias
        python3 -c "
import json
from datetime import datetime, timedelta
ufile = '/etc/zivpn/users.json'
try:
    with open(ufile, 'r') as f: users = json.load(f)
except: users = []
user = '$nome'; days = int('$dias')
for u in users:
    if u.get('user','').lower() == user.lower():
        old_exp = u.get('expires', datetime.now().strftime('%Y-%m-%d'))
        try:
            dt = datetime.strptime(old_exp, '%Y-%m-%d')
            if dt.date() < datetime.now().date(): dt = datetime.now()
        except: dt = datetime.now()
        new_exp = (dt + timedelta(days=days)).strftime('%Y-%m-%d')
        u['expires'] = new_exp
        break
with open(ufile, 'w') as f: json.dump(users, f, indent=2)
"
        update_zivpn
        echo -e "\n\033[1;32m✅ Account '$nome' သက်တမ်းတိုးပြီးပါပြီ!\033[0m"
        read -n 1 -s -r -p "Press any key to return..."
        ;;
    4)
        clear
        echo -e "\E[44;1;37m        ZIVPN ACCOUNT LIST         \E[0m"
        echo ""
        python3 -c "
import json
try:
    with open('/etc/zivpn/users.json', 'r') as f: users = json.load(f)
    print(f'Total Users: {len(users)}\n')
    for u in users:
        print(f\"👤 {u.get('user')}  |  🔑 {u.get('password')}  |  ⏳ {u.get('expires')}\")
except:
    print('No users found.')
"
        echo ""
        read -n 1 -s -r -p "Press any key to return..."
        ;;
    0)
        clear
        exit 0
        ;;
    *)
        echo -e "\n\033[1;31mမှားယွင်းနေပါသည်။ ပြန်ရွေးပါ။\033[0m"
        sleep 1
        ;;
esac
done
