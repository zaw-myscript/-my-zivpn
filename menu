print('\033[1;36mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\033[0m')
print('\033[1;33m{:<15} | {:<12} | {:<12} | {}\033[0m'.format('USERNAME', 'PASSWORD', 'EXPIRES', 'STATUS'))
print('\033[1;36mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\033[0m')
try:
    with open('/etc/zivpn/users.json', 'r') as f: users = json.load(f)
    if not users:
        print('\033[1;31m   бҖЎбҖҖбҖұбҖ¬бҖ„бҖ·бҖәбҖҷбҖ»бҖ¬бҖё бҖҷбҖӣбҖҫбҖӯбҖһбҖұбҖёбҖ•бҖ«бҒӢ (No users found)\033[0m')
    else:
        for u in users:
            user = u.get('user', '')
            pwd = u.get('password', '')
            exp = u.get('expires', '')
            status = '\033[1;32mActive\033[0m'
            if exp:
                try:
                    if datetime.strptime(exp, '%Y-%m-%d').date() < datetime.now().date():
                        status = '\033[1;31mExpired\033[0m'
                except: pass
            print('\033[1;37m{:<15} \033[1;36m|\033[1;37m {:<12} \033[1;36m|\033[1;37m {:<12} \033[1;36m|\033[0m {}'.format(user, pwd, exp, status))
except:
    print('\033[1;31m   бҖЎбҖҖбҖұбҖ¬бҖ„бҖ·бҖәбҖҷбҖ»бҖ¬бҖё бҖҷбҖӣбҖҫбҖӯбҖһбҖұбҖёбҖ•бҖ«бҒӢ\033[0m')
print('\033[1;36mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\033[0m')
"
        echo ""
        read -n 1 -s -r -p "Press any key to return..."
        ;;
    0)
        clear
        exit 0
        ;;
    *)
        echo -e "\n\033[1;31mбҖҷбҖҫбҖ¬бҖёбҖҡбҖҪбҖ„бҖәбҖёбҖ”бҖұбҖ•бҖ«бҖһбҖҠбҖәбҒӢ бҖ•бҖјбҖ”бҖәбҖӣбҖҪбҖұбҖёбҖ•бҖ«бҒӢ\033[0m"
        sleep 1
        ;;
esac
done
